# Banco de Dados
MONGO_URI=mongodb://localhost:27017/checkout

# JWT
JWT_SECRET=your_jwt_secret_here

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CLIENT_ID=ca_...

# Cloudinary (Upload de Imagens)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# API Externa (Webhook de Vendas)
# URL da API que receberá as notificações de venda
EXTERNAL_API_URL=https://api.exemplo.com/webhooks/sales
# Chave de autenticação (opcional)
EXTERNAL_API_KEY=your_api_key_here

# Pagar.me
PAGARME_API_URL=https://api.pagar.me/core/v5

# Encriptação (para credenciais sensíveis)
# IMPORTANTE: Gere uma chave forte e única para produção
# Exemplo: openssl rand -base64 32
ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# Super Admin (senha root para acesso ao painel de super admin)
SUPER_ADMIN_PASSWORD=your_super_admin_password_here

# Email de Abandono de Carrinho (SMTP do Snapp - enviado sempre deste remetente)
SNAPP_SMTP_HOST=smtp.exemplo.com
SNAPP_SMTP_PORT=587
SNAPP_SMTP_USER=noreply@snappcheckout.com
SNAPP_SMTP_PASS=your_smtp_password_here
SNAPP_FROM_EMAIL=noreply@snappcheckout.com
SNAPP_FROM_NAME=Snapp
# URL base do checkout (ex: https://checkout.snappcheckout.com)
CHECKOUT_BASE_URL=https://checkout.snappcheckout.com

# Server
PORT=5000
NODE_ENV=development
